# Supabase (placeholders only — no real project exists yet)
# SUPABASE_URL is the bare project URL — do NOT append /rest/v1/ (the Data API
# path shown on some Supabase dashboard pages); the SDKs append their own
# suffixes (/storage/v1, /auth/v1, /rest/v1) internally.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma / Postgres (Supabase connection strings)
# DATABASE_URL uses the pooled connection (port 6543, PgBouncer transaction mode) — the
# `pgbouncer=true` param is required or Prisma will fail with "prepared statement already exists".
# DIRECT_URL uses the direct connection (port 5432), no pgbouncer param.
DATABASE_URL=postgresql://postgres.[project-ref]:password@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.[project-ref].supabase.co:5432/postgres

# Redis (BullMQ) — docker-compose locally, Upstash/Railway in production
REDIS_URL=redis://localhost:6379

# Sentry
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Only needed for apps/web's build-time source map upload — leave unset to skip it.
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token

# API
PORT=3001
# Comma-separated list of origins the API accepts CORS requests from. Defaults to
# http://localhost:3000 if unset (see resolveAllowedOrigins in apps/api/src/main.ts) —
# set this to your real web domain(s) before serving production traffic.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Next.js public envs consumed client-side (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001
# Client-side Sentry init needs its own NEXT_PUBLIC_ var — a DSN is meant to be public,
# this isn't a secret duplicate of SENTRY_DSN above, just the browser-visible copy.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
