  notified_at       DateTime      @default(now())
  notification_type String
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  deleted_at        DateTime?

  @@index([organization_id])
  @@index([qualification_id])
  @@map("qualification_expiries")
}

