  reported_by     String?      @db.Uuid
  status          String       @default("aberta")
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@map("safety_occurrences")
}

