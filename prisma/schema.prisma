// Orion Flight Lab — Prisma schema
//
// Convention: every model has id (uuid, gen_random_uuid()), created_at,
// updated_at, deleted_at (soft-delete) and organization_id (multi-tenant),
// except: Organization itself (the tenant root) and AuditLog (immutable,
// insert-only, no updated_at/deleted_at by design — see supabase/migrations
// for the RLS policy that enforces this at the database level).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  GERENTE_QUALIDADE
  GERENTE_SEGURANCA
  COORDENADOR_ACADEMICO
  INSTRUTOR
  EXAMINADOR
  SECRETARIA_ACADEMICA
  COMERCIAL
  FINANCEIRO
  ALUNO
}

enum ExpiryStatus {
  EM_DIA
  A_VENCER
  VENCIDO
}

enum DocumentApprovalStatus {
  EM_ELABORACAO
  SUBMETIDO_ANAC
  APROVADO
  EM_REVISAO
  EMENDADO
}

enum EnrollmentStatus {
  ATIVA
  CONCLUIDA
  TRANCADA
  CANCELADA
  EXPIRADA
}

enum CourseStatus {
  ATIVO
  ALERTA_INATIVIDADE
  SUSPENSO
  ENCERRADO
}

enum ExamType {
  TEORICO
  PRATICO
}

enum ExamResult {
  APROVADO
  REPROVADO
  PENDENTE
}

enum ClientType {
  PF
  PJ
}

// ---------------------------------------------------------------------------
// Auth / IAM
// ---------------------------------------------------------------------------

/// Mirrors a Supabase auth.users row. The id is the same UUID as the
/// corresponding auth.users.id (set explicitly on creation, not generated).
model UserProfile {
  id              String       @id @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  email           String       @unique
  full_name       String
  phone           String?
  avatar_url      String?
  roles           Role[]
  active          Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  instructor Instructor?
  examiner   Examiner?
  student    Student?

  @@index([organization_id])
  @@map("user_profiles")
}

/// Append-only audit trail. No updated_at/deleted_at — rows are immutable
/// by design (see audit_log_insert_only RLS policy).
model AuditLog {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  actor_user_id   String?      @db.Uuid
  action          String
  entity          String
  entity_id       String?      @db.Uuid
  payload         Json?
  created_at      DateTime     @default(now())

  @@index([organization_id])
  @@index([entity, entity_id])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Organization
// ---------------------------------------------------------------------------

/// The CTAC itself — tenant root. Has no organization_id.
model Organization {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  cnpj           String    @unique
  anac_ctac_code String    @unique
  address        String?
  city           String?
  state          String?
  active         Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  userProfiles          UserProfile[]
  auditLogs             AuditLog[]
  satellites            CTACSatellite[]
  remotes               CTACRemote[]
  trainingSpecs         TrainingSpec[]
  instructors           Instructor[]
  examiners             Examiner[]
  trainingPrograms      TrainingProgram[]
  students              Student[]
  documents             Document[]
  clients               Client[]
  contracts             Contract[]
  aircraftQualification AircraftQualification[]
  cMA                   CMA[]
  proficiency           Proficiency[]
  courseAssignment      CourseAssignment[]
  curriculum            Curriculum[]
  course                Course[]
  segment               Segment[]
  module                Module[]
  unit                  Unit[]
  subUnit               SubUnit[]
  lesson                Lesson[]
  material              Material[]
  trainingDevice        TrainingDevice[]
  enrollment            Enrollment[]
  attendance            Attendance[]
  theoryExam            TheoryExam[]
  practicalExam         PracticalExam[]
  grade                 Grade[]
  certificate           Certificate[]
  qualification         Qualification[]
  qualificationExpiry   QualificationExpiry[]
  documentVersion       DocumentVersion[]
  documentApproval      DocumentApproval[]
  auditProgram          AuditProgram[]
  audit                 Audit[]
  nonConformity         NonConformity[]
  correctiveAction      CorrectiveAction[]
  qualityReport         QualityReport[]
  hazard                Hazard[]
  risk                  Risk[]
  mitigation            Mitigation[]
  mGSO                  MGSO[]
  pRE                   PRE[]
  safetyOccurrence      SafetyOccurrence[]
  semestralReport       SemestralReport[]
  iDSO                  IDSO[]
  clientUnit            ClientUnit[]
  contact               Contact[]
  account               Account[]
  proposal              Proposal[]
  pipeline              Pipeline[]
  contractAmendment     ContractAmendment[]
  plan                  Plan[]
  subscription          Subscription[]
  charge                Charge[]
  payment               Payment[]
  delinquency           Delinquency[]
  instructorLessonLogs  InstructorLessonLog[]

  @@map("organizations")
}

model CTACSatellite {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  name            String
  address         String?
  anac_code       String?
  active          Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@map("ctac_satellites")
}

model CTACRemote {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  name            String
  address         String?
  anac_code       String?
  active          Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@map("ctac_remotes")
}

model TrainingSpec {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  name            String
  code            String
  description     String?
  anac_reference  String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@map("training_specs")
}

// ---------------------------------------------------------------------------
// Personnel
// ---------------------------------------------------------------------------

model Instructor {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String       @db.Uuid
  organization      Organization @relation(fields: [organization_id], references: [id])
  user_profile_id   String?      @unique @db.Uuid
  userProfile       UserProfile? @relation(fields: [user_profile_id], references: [id])
  full_name         String
  cpf               String       @unique
  anac_registration String?
  active            Boolean      @default(true)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  deleted_at        DateTime?

  qualifications    AircraftQualification[]
  cmas              CMA[]
  proficiencies     Proficiency[]
  courseAssignments CourseAssignment[]
  lessonLogs        InstructorLessonLog[]

  @@index([organization_id])
  @@map("instructors")
}

model Examiner {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String       @db.Uuid
  organization       Organization @relation(fields: [organization_id], references: [id])
  user_profile_id    String?      @unique @db.Uuid
  userProfile        UserProfile? @relation(fields: [user_profile_id], references: [id])
  full_name          String
  cpf                String       @unique
  anac_accreditation String?
  active             Boolean      @default(true)
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  deleted_at         DateTime?

  qualifications AircraftQualification[]

  @@index([organization_id])
  @@map("examiners")
}

/// Belongs to either an Instructor OR an Examiner (exactly one, enforced in
/// application logic per RN-17 / RN-18 — max 2 aircraft types each).
model AircraftQualification {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String       @db.Uuid
  organization       Organization @relation(fields: [organization_id], references: [id])
  instructor_id      String?      @db.Uuid
  instructor         Instructor?  @relation(fields: [instructor_id], references: [id])
  examiner_id        String?      @db.Uuid
  examiner           Examiner?    @relation(fields: [examiner_id], references: [id])
  aircraft_type      String
  qualification_type String?
  issued_at          DateTime
  expires_at         DateTime
  status             ExpiryStatus @default(EM_DIA)
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  deleted_at         DateTime?

  @@index([organization_id])
  @@index([instructor_id])
  @@index([examiner_id])
  @@map("aircraft_qualifications")
}

model CMA {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  instructor_id   String       @db.Uuid
  instructor      Instructor   @relation(fields: [instructor_id], references: [id])
  document_url    String?
  issued_at       DateTime
  expires_at      DateTime
  status          ExpiryStatus @default(EM_DIA)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([instructor_id])
  @@map("cmas")
}

/// Annual proficiency evaluation. RN-16: renewal window is 45 days before/after
/// expires_at.
model Proficiency {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  instructor_id   String       @db.Uuid
  instructor      Instructor   @relation(fields: [instructor_id], references: [id])
  evaluated_at    DateTime
  valid_until     DateTime
  result          ExamResult   @default(PENDENTE)
  evaluator_name  String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([instructor_id])
  @@map("proficiencies")
}

model CourseAssignment {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  instructor_id   String       @db.Uuid
  instructor      Instructor   @relation(fields: [instructor_id], references: [id])
  course_id       String       @db.Uuid
  course          Course       @relation(fields: [course_id], references: [id])
  role            String       @default("instrutor")
  assigned_at     DateTime     @default(now())
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([instructor_id])
  @@index([course_id])
  @@map("course_assignments")
}

/// Log of lesson deliveries per instructor, used to enforce RN-15 (an
/// instructor cannot teach more than 8h within any rolling 24h window).
model InstructorLessonLog {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  instructor_id   String       @db.Uuid
  instructor      Instructor   @relation(fields: [instructor_id], references: [id])
  course_id       String?      @db.Uuid
  lesson_id       String?      @db.Uuid
  hours           Decimal      @db.Decimal(5, 2)
  delivered_at    DateTime
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([instructor_id])
  @@index([delivered_at])
  @@map("instructor_lesson_logs")
}

// ---------------------------------------------------------------------------
// Training
// ---------------------------------------------------------------------------

model TrainingProgram {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  name            String
  code            String
  anac_reference  String?
  description     String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  curricula Curriculum[]

  @@index([organization_id])
  @@map("training_programs")
}

model Curriculum {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id     String          @db.Uuid
  organization        Organization    @relation(fields: [organization_id], references: [id])
  training_program_id String          @db.Uuid
  trainingProgram     TrainingProgram @relation(fields: [training_program_id], references: [id])
  name                String
  version             String
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  deleted_at          DateTime?

  courses Course[]

  @@index([organization_id])
  @@index([training_program_id])
  @@map("curricula")
}

model Course {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id  String       @db.Uuid
  organization     Organization @relation(fields: [organization_id], references: [id])
  curriculum_id    String       @db.Uuid
  curriculum       Curriculum   @relation(fields: [curriculum_id], references: [id])
  name             String
  code             String
  status           CourseStatus @default(ATIVO)
  max_students     Int          @default(25)
  start_date       DateTime?
  end_date         DateTime?
  last_activity_at DateTime     @default(now())
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  deleted_at       DateTime?

  segments          Segment[]
  enrollments       Enrollment[]
  courseAssignments CourseAssignment[]

  @@index([organization_id])
  @@index([curriculum_id])
  @@map("courses")
}

model Segment {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  course_id       String       @db.Uuid
  course          Course       @relation(fields: [course_id], references: [id])
  name            String
  order           Int          @default(0)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  modules Module[]

  @@index([organization_id])
  @@index([course_id])
  @@map("segments")
}

model Module {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  segment_id      String       @db.Uuid
  segment         Segment      @relation(fields: [segment_id], references: [id])
  name            String
  order           Int          @default(0)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  units Unit[]

  @@index([organization_id])
  @@index([segment_id])
  @@map("modules")
}

model Unit {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  module_id       String       @db.Uuid
  module          Module       @relation(fields: [module_id], references: [id])
  name            String
  order           Int          @default(0)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  subUnits SubUnit[]

  @@index([organization_id])
  @@index([module_id])
  @@map("units")
}

model SubUnit {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  unit_id         String       @db.Uuid
  unit            Unit         @relation(fields: [unit_id], references: [id])
  name            String
  order           Int          @default(0)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  lessons Lesson[]

  @@index([organization_id])
  @@index([unit_id])
  @@map("sub_units")
}

model Lesson {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  sub_unit_id     String       @db.Uuid
  subUnit         SubUnit      @relation(fields: [sub_unit_id], references: [id])
  name            String
  duration_hours  Decimal      @default(1) @db.Decimal(5, 2)
  order           Int          @default(0)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  materials   Material[]
  attendances Attendance[]

  @@index([organization_id])
  @@index([sub_unit_id])
  @@map("lessons")
}

model Material {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  lesson_id       String       @db.Uuid
  lesson          Lesson       @relation(fields: [lesson_id], references: [id])
  name            String
  file_url        String?
  type            String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([lesson_id])
  @@map("materials")
}

model TrainingDevice {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String       @db.Uuid
  organization      Organization @relation(fields: [organization_id], references: [id])
  name              String
  type              String
  registration_code String?
  active            Boolean      @default(true)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  deleted_at        DateTime?

  @@index([organization_id])
  @@map("training_devices")
}

// ---------------------------------------------------------------------------
// Academic
// ---------------------------------------------------------------------------

/// Ficha ANAC do aluno (Seção 142.71).
model Student {
  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id        String       @db.Uuid
  organization           Organization @relation(fields: [organization_id], references: [id])
  user_profile_id        String?      @unique @db.Uuid
  userProfile            UserProfile? @relation(fields: [user_profile_id], references: [id])
  full_name              String
  cpf                    String       @unique
  anac_record_number     String?      @unique
  birth_date             DateTime?
  fraud_quarantine_until DateTime?
  active                 Boolean      @default(true)
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  deleted_at             DateTime?

  enrollments    Enrollment[]
  certificates   Certificate[]
  qualifications Qualification[]

  @@index([organization_id])
  @@map("students")
}

model Enrollment {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String           @db.Uuid
  organization    Organization     @relation(fields: [organization_id], references: [id])
  student_id      String           @db.Uuid
  student         Student          @relation(fields: [student_id], references: [id])
  course_id       String           @db.Uuid
  course          Course           @relation(fields: [course_id], references: [id])
  status          EnrollmentStatus @default(ATIVA)
  enrolled_at     DateTime         @default(now())
  proof_url       String?
  completed_at    DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  deleted_at      DateTime?

  attendances    Attendance[]
  theoryExams    TheoryExam[]
  practicalExams PracticalExam[]
  grades         Grade[]
  certificates   Certificate[]

  @@index([organization_id])
  @@index([student_id])
  @@index([course_id])
  @@map("enrollments")
}

model Attendance {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  enrollment_id   String       @db.Uuid
  enrollment      Enrollment   @relation(fields: [enrollment_id], references: [id])
  lesson_id       String       @db.Uuid
  lesson          Lesson       @relation(fields: [lesson_id], references: [id])
  date            DateTime
  present         Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([enrollment_id])
  @@index([lesson_id])
  @@map("attendances")
}

/// Seção 142.71a6 — registro de exame com instrutor/examinador responsável.
model TheoryExam {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  enrollment_id   String       @db.Uuid
  enrollment      Enrollment   @relation(fields: [enrollment_id], references: [id])
  instructor_id   String?      @db.Uuid
  examiner_id     String?      @db.Uuid
  exam_date       DateTime
  score           Decimal?     @db.Decimal(5, 2)
  result          ExamResult   @default(PENDENTE)
  attempt_number  Int          @default(1)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([enrollment_id])
  @@map("theory_exams")
}

model PracticalExam {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  enrollment_id   String       @db.Uuid
  enrollment      Enrollment   @relation(fields: [enrollment_id], references: [id])
  instructor_id   String?      @db.Uuid
  examiner_id     String?      @db.Uuid
  exam_date       DateTime
  score           Decimal?     @db.Decimal(5, 2)
  result          ExamResult   @default(PENDENTE)
  attempt_number  Int          @default(1)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([enrollment_id])
  @@map("practical_exams")
}

model Grade {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  enrollment_id   String       @db.Uuid
  enrollment      Enrollment   @relation(fields: [enrollment_id], references: [id])
  subject         String
  score           Decimal      @db.Decimal(5, 2)
  weight          Decimal      @default(1) @db.Decimal(5, 2)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([enrollment_id])
  @@map("grades")
}

/// RN-05: only issued when all course requirements are complete.
model Certificate {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String       @db.Uuid
  organization       Organization @relation(fields: [organization_id], references: [id])
  enrollment_id      String       @db.Uuid
  enrollment         Enrollment   @relation(fields: [enrollment_id], references: [id])
  student_id         String       @db.Uuid
  student            Student      @relation(fields: [student_id], references: [id])
  certificate_number String       @unique
  issued_at          DateTime     @default(now())
  file_url           String?
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  deleted_at         DateTime?

  @@index([organization_id])
  @@index([enrollment_id])
  @@index([student_id])
  @@map("certificates")
}

model Qualification {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String       @db.Uuid
  organization       Organization @relation(fields: [organization_id], references: [id])
  student_id         String       @db.Uuid
