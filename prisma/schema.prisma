// ---------------------------------------------------------------------------
// SGSO — Sistema de Gerenciamento da Segurança Operacional
// ---------------------------------------------------------------------------

model Hazard {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  description     String
  source          String?
  identified_at   DateTime     @default(now())
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  risks             Risk[]
  safetyOccurrences SafetyOccurrence[]

  @@index([organization_id])
  @@map("hazards")
}

model Risk {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  hazard_id       String       @db.Uuid
  hazard          Hazard       @relation(fields: [hazard_id], references: [id])
  probability     Int
  severity        Int
  risk_level      String?
  /// RN-27: "aceito"/"mitigado" only reachable once a Mitigation exists, when risk_level is high.
  status          String       @default("identificado")
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  mitigations Mitigation[]

  @@index([organization_id])
  @@index([hazard_id])
  @@map("risks")
}

model Mitigation {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  organization    Organization @relation(fields: [organization_id], references: [id])
  risk_id         String       @db.Uuid
  risk            Risk         @relation(fields: [risk_id], references: [id])
  description     String
  responsible     String?
  implemented_at  DateTime?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@index([risk_id])
  @@map("mitigations")
}

/// Manual do Sistema de Gerenciamento da Segurança Operacional.
model MGSO {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
